# =========================================================================
# EAN Pictures — exemplo de variáveis de ambiente
# Copie para `.env` e ajuste os valores. NÃO versione o seu `.env` real.
# Todas as variáveis são OPCIONAIS — o projeto roda sem nenhuma delas.
# =========================================================================

# -------------------------------------------------------------------------
# Provedores de consulta (cascata)
# -------------------------------------------------------------------------
# Lista separada por vírgula, consultada em ordem até encontrar o produto.
# Opções: cosmos | ean-db | upcitemdb | openfoodfacts | ean-search
# Padrão: upcitemdb,openfoodfacts
# Recomendado p/ BR + internacional: cosmos,ean-db,upcitemdb,openfoodfacts
# Em uso: cosmos (provedor único; imagem faltante é preenchida via SerpAPI abaixo).
EAN_API_PROVIDER=cosmos

# Sobrescreve o endpoint base do PRIMEIRO provedor (uso avançado/testes).
EAN_API_BASE_URL=

# -------------------------------------------------------------------------
# Tokens de autenticação
# -------------------------------------------------------------------------
# Token global: usado como fallback por qualquer provedor autenticado.
EAN_API_TOKEN=

# Tokens específicos por provedor (têm prioridade sobre o global).
# Permitem encadear vários serviços autenticados com chaves diferentes.
COSMOS_TOKEN=        # Bluesoft Cosmos (BR) — https://cosmos.bluesoft.com.br
EAN_DB_TOKEN=        # EAN-DB (JWT) — https://ean-db.com
EAN_SEARCH_TOKEN=    # EAN-Search — https://www.ean-search.org

# RSC Sistemas GTIN (BR) — https://gtin.rscsistemas.com.br
# Recomendado: usuário + senha (auto-login; o token de 1h é renovado sozinho).
GTIN_USER=
GTIN_PASSWORD=
# Alternativa manual: token estático (usado só se USER/PASSWORD vazios).
GTIN_TOKEN=

# Base URL própria por provedor (opcional; sobrescreve o default).
GTIN_BASE_URL=https://gtin.rscsistemas.com.br

# -------------------------------------------------------------------------
# Cache
# -------------------------------------------------------------------------
# Backend do cache: sqlite (persiste em disco, padrão) ou memory (some ao reiniciar).
EAN_CACHE_BACKEND=sqlite
# Caminho do banco SQLite do cache (padrão: data/cache.db).
EAN_CACHE_PATH=data/cache.db
# TTL do cache, em segundos. 0 = nunca expira. Padrão: 3600 (1 hora).
EAN_CACHE_TTL=3600

# Merge de imagem na cascata: herda a foto de um provedor posterior mantendo o
# nome/dados do preferido. 1 = ligado (padrão), 0 = desligado.
EAN_MERGE_IMAGE=1

# -------------------------------------------------------------------------
# Fallback de imagem por nome (quando o produto vem SEM foto)
# -------------------------------------------------------------------------
# Backend: vazio (desligado) | google | serpapi
# Em uso: serpapi (mais simples — só uma chave, sem mecanismo/cx).
IMAGE_SEARCH_PROVIDER=serpapi

# SerpAPI (engine google_images) — https://serpapi.com
# Cadastre-se e copie a chave em Dashboard -> Your API Key.
# Plano grátis: 100 buscas/mês (o cache evita repetir o mesmo EAN).
SERPAPI_KEY=

# Google Custom Search JSON API (alternativa ao SerpAPI — 100 buscas/dia grátis):
#   chave: https://developers.google.com/custom-search/v1/overview
#   cx (mecanismo): https://programmablesearchengine.google.com (ative "Buscar imagens")
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# -------------------------------------------------------------------------
# Consulta em lote (batch)
# -------------------------------------------------------------------------
# Nº de consultas paralelas no lote.
BATCH_MAX_WORKERS=8
# Tamanho máximo do upload (PDF/CSV/XLSX), em MB.
MAX_UPLOAD_MB=10

# -------------------------------------------------------------------------
# Rate limit dos endpoints /api/*
# -------------------------------------------------------------------------
# Máximo de requisições por IP dentro da janela.
RATE_LIMIT_MAX=30
# Tamanho da janela do rate limit, em segundos.
RATE_LIMIT_WINDOW=60

# -------------------------------------------------------------------------
# Servidor
# -------------------------------------------------------------------------
# Interface de bind. 127.0.0.1 = só local (seguro). 0.0.0.0 = expõe na rede.
HOST=127.0.0.1
# Porta do servidor.
PORT=5000
# Modo debug do Flask. 1 = ligado (APENAS em desenvolvimento — risco de RCE).
FLASK_DEBUG=0
